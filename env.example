# ── BingX ────────────────────────────────────────────────────────
BINGX_API_KEY=tu_api_key
BINGX_API_SECRET=tu_api_secret

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=tu_chat_id

# ── Símbolo (vacío = auto-scanner) ───────────────────────────────
SYMBOL=

# ── Timeframes ────────────────────────────────────────────────────
INTERVAL=3m
HTF_INTERVAL=15m

# ── Trading ───────────────────────────────────────────────────────
LEVERAGE=5
DEMO_MODE=false

# ── Estrategia ────────────────────────────────────────────────────
EMA1_LEN=2
EMA2_LEN=4
EMA3_LEN=20
SCORE_MIN=30

# ── Riesgo ────────────────────────────────────────────────────────
RISK_PCT=1.0
ATR_SL_MULT=1.5
MAX_DD_PCT=10.0

# ── Scanner ───────────────────────────────────────────────────────
SCANNER_TOP_N=1
MIN_VOLUME=1000000

# ── Heartbeat (cada N velas) ──────────────────────────────────────
HEARTBEAT_EVERY=20
