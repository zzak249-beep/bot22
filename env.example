# ═══════════════════════════════════════════════════════
# BingX SuperBot - Environment Variables
# Copy these to Railway → Service → Variables tab
# ═══════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────
BINGX_API_KEY=your_api_key_here
BINGX_API_SECRET=your_api_secret_here

# ── SAFETY: Start with DRY_RUN=true for at least 3-7 days ─
DRY_RUN=true

# ── TELEGRAM ALERTS (optional but recommended) ────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── TRADING PARAMETERS ────────────────────────────────────
SCAN_PERIOD_SECONDS=900     # How often to scan (15 min default)
MAX_OPEN_TRADES=5           # Max concurrent positions
LEVERAGE=5                  # Leverage (5x = conservative)
RISK_PER_TRADE=0.01         # 1% of balance per trade
DAILY_LOSS_LIMIT=0.05       # 5% daily drawdown kill switch

# ── ORDER SETTINGS ────────────────────────────────────────
LIMIT_ENTRY=true            # Use LIMIT orders (maker fee = 60% cheaper)
SLIPPAGE_OFFSET=0.0003      # 0.03% offset for limit fill probability
LIMIT_ORDER_TIMEOUT=120     # Cancel unfilled limit orders after 2 min
