# =============================================
#  BB+RSI DCA BOT — Variables de entorno
#  Copia este archivo como .env y rellena
#  En Railway: Settings > Variables > Raw Editor
# =============================================

# ── BingX API (obligatorio para modo real) ──
BINGX_API_KEY=PEGA_TU_API_KEY_AQUI
BINGX_SECRET=PEGA_TU_SECRET_AQUI

# ── Telegram (obligatorio para notificaciones) ──
# 1. Habla con @BotFather en Telegram -> /newbot -> copia el token
TG_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2. Habla con @userinfobot -> copia el numero (con el - si lo tiene)
TG_CHAT_ID=123456789

# ── Pares a operar (separados por coma, sin espacios) ──
SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT,XRP/USDT

# ── Estrategia ──
TIMEFRAME=1h
BB_PERIOD=30
BB_SIGMA=1.8
RSI_PERIOD=14
RSI_OB=65
SL_ATR=2.0

# ── Capital y riesgo ──
RISK_PCT=0.02
LEVERAGE=3
MAX_POSITIONS=3
COOLDOWN_BARS=3
MIN_USDT_BALANCE=5

# ── Operacion ──
LOOP_SECONDS=300
