# ══════════════════════════════════════════════════════
#  VARIABLES RAILWAY — Bellsz Bot v2.0
#  Copia estas variables en Railway → Variables
# ══════════════════════════════════════════════════════

# ── OBLIGATORIAS ──────────────────────────────────────
BINGX_API_KEY=TU_API_KEY_AQUI
BINGX_SECRET_KEY=TU_SECRET_KEY_AQUI
TELEGRAM_TOKEN=TU_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=TU_CHAT_ID

# ── General ───────────────────────────────────────────
MEMORY_DIR=/app/data
MODO_DEMO=false
BINGX_MODE=auto
VERSION=Bellsz Bot v2.0
LOG_LEVEL=INFO

# ── Capital ───────────────────────────────────────────
TRADE_USDT_BASE=10
TRADE_USDT_MAX=100
LEVERAGE=10
COMPOUND_STEP_USDT=50
COMPOUND_ADD_USDT=5

# ── Estrategia Bellsz (ÓPTIMOS del backtest) ──────────
TIMEFRAME=5m
LIQ_LOOKBACK=30
LIQ_MARGEN=0.15
TP_DIST_MULT=3.0
TP1_DIST_MULT=1.5
SL_ATR_MULT=1.5
MIN_RR=2.0
SCORE_MIN=5

# ── Indicadores ───────────────────────────────────────
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
RSI_BUY_MAX=70
RSI_SELL_MIN=30
ATR_PERIOD=14
ADX_MIN=8
ATR_MIN_PCT=0.02

# ── Filtros adicionales ───────────────────────────────
VWAP_ACTIVO=true
VWAP_PCT=0.5
OB_ACTIVO=true
OB_LOOKBACK=30
BOS_ACTIVO=true
FVG_ACTIVO=true
SWEEP_ACTIVO=true
SWEEP_LOOKBACK=20
DISPLACEMENT_ACTIVO=true
PREMIUM_DISCOUNT_ACTIVO=true
CORRELACION_ACTIVO=true

# ── Gestión de posiciones ─────────────────────────────
MAX_POSICIONES=3
COOLDOWN_VELAS=5
MAX_PERDIDA_DIA=30
TIME_EXIT_HORAS=8
BE_ACTIVO=true
TRAILING_ACTIVO=true
TRAILING_ACTIVAR=1.5
TRAILING_DISTANCIA=1.0
PARTIAL_TP_ACTIVO=true

# ── MTF / HTF ─────────────────────────────────────────
MTF_ACTIVO=true
MTF_TIMEFRAME=1h
MTF_4H_ACTIVO=true
HTF_H1_TF=1h
HTF_H4_TF=4h
HTF_D_TF=1d
HTF_CANDLES=60
CANDLES_LIMIT=200

# ── Scanner ───────────────────────────────────────────
MAX_PARES_SCAN=30
VOLUMEN_MIN_24H=5000000
ANALISIS_WORKERS=4
SOLO_LONG=false
PARES_BLOQUEADOS=RESOLV-USDT

# ── Loop ─────────────────────────────────────────────
LOOP_SECONDS=90

# ── Killzones (UTC en minutos) ────────────────────────
KZ_ASIA_START=0
KZ_ASIA_END=240
KZ_LONDON_START=420
KZ_LONDON_END=600
KZ_NY_START=780
KZ_NY_END=960
KZ_REQUERIDA=false

# ── MetaClaw (opcional) ───────────────────────────────
METACLAW_ACTIVO=false
# ANTHROPIC_API_KEY=tu_key_si_usas_metaclaw
