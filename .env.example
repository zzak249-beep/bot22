# ── BingX API ────────────────────────────────────────────────
BINGX_API_KEY=your_bingx_api_key_here
BINGX_SECRET=your_bingx_secret_here

# ── Telegram ─────────────────────────────────────────────────
TG_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here

# ── Strategy ─────────────────────────────────────────────────
SYMBOL=BTC-USDT
TIMEFRAME=15m         # 1m 3m 5m 15m 30m 1h 4h
ATR_MULTIPLIER=1.5

# ── Risk ─────────────────────────────────────────────────────
RISK_PCT=1.0          # % of balance risked per trade
LEVERAGE=10           # 1-100 (start low!)

# ── Bot behavior ─────────────────────────────────────────────
POLL_SECONDS=60       # how often to check for signals
SIGNALS_ONLY=false    # true = only send Telegram alerts, no real orders
HEARTBEAT_HOURS=4     # send alive ping every N hours
