BINGX_API_KEY=TU_API_KEY_AQUI
BINGX_SECRET_KEY=TU_SECRET_KEY_AQUI

TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890

# Scanner
TIMEFRAME=3m
SCAN_INTERVAL=60
MAX_SYMBOLS=80
CONCURRENT_SCANS=10
MIN_VOLUME_USDT=500000

# Capital y riesgo
CAPITAL=1000.0
RISK_PCT=1.0
LEVERAGE=10
TP1_MULT=1.5
TP2_MULT=3.0
SL_MULT=1.0
MAX_OPEN_TRADES=5
MAX_DAILY_TRADES=20

# Filtros
MIN_TIER=FUEL
REQUIRE_TL_BREAK=true
TRADE_PRE_SIGNALS=false
HTF_MIN=2
SC_THR_PRE=48
SC_THR_STD=55
SC_THR_FUEL=68
SC_THR_SUP=80
