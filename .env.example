# ========================================
# CREDENCIALES BINGX
# ========================================
BINGX_API_KEY=your_api_key_here
BINGX_API_SECRET=your_api_secret_here

# ========================================
# TELEGRAM (Opcional)
# ========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ========================================
# TRADING PARAMETERS
# ========================================
AUTO_TRADING_ENABLED=false  # true para activar trading real
MAX_POSITION_SIZE=100  # Tamaño de posición en USDT
LEVERAGE=2  # Apalancamiento (1-125)

# ========================================
# RISK MANAGEMENT
# ========================================
TAKE_PROFIT_PCT=2.0  # Take profit en %
STOP_LOSS_PCT=1.0    # Stop loss en %
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ACTIVATION=1.0  # % de ganancia para activar trailing
TRAILING_STOP_DISTANCE=0.5     # % de distancia del trailing stop

MAX_OPEN_TRADES=5     # Máximo de trades simultáneos
MAX_DAILY_LOSS=500    # Pérdida máxima diaria en USDT
MAX_DRAWDOWN_PCT=10   # Drawdown máximo permitido en %

# ========================================
# MARKET SCANNING
# ========================================
MIN_VOLUME_24H=1000000    # Volumen mínimo 24h en USDT
MIN_PRICE=0.0001          # Precio mínimo
MAX_SYMBOLS_TO_TRADE=50   # Máximo de símbolos a analizar

# ========================================
# MACHINE LEARNING
# ========================================
ML_ENABLED=true                 # Activar ML/IA
ML_CONFIDENCE_THRESHOLD=0.65    # Confianza mínima para ejecutar (0-1)
ML_RETRAIN_INTERVAL=3600        # Segundos entre re-entrenamientos

# ========================================
# TECHNICAL ANALYSIS
# ========================================
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

BB_PERIOD=20
BB_STD_DEV=2.0

PRIMARY_TIMEFRAME=5m  # 1m, 5m, 15m, 1h, 4h, 1d

# ========================================
# INTERVALS
# ========================================
CHECK_INTERVAL=60           # Segundos entre análisis
MARKET_SCAN_INTERVAL=300    # Segundos entre actualización de símbolos

# ========================================
# DATABASE
# ========================================
DB_PATH=trading_bot.db

# ========================================
# DASHBOARD (Opcional)
# ========================================
DASHBOARD_ENABLED=false
DASHBOARD_PORT=8080
DASHBOARD_UPDATE_INTERVAL=10

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=trading_bot.log
