# ── OBLIGATORIAS ──────────────────────────────────────────────
# Claves de BingX (Perpetual Futures)
# Obtén las tuyas en: https://bingx.com/en-us/account/api/
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui

# ── CONFIGURACIÓN DEL BOT ─────────────────────────────────────
# Par a operar (formato BingX: BASE-QUOTE)
SYMBOL=BTC-USDT

# Temporalidad (1m, 3m, 5m, 15m, 30m, 1h, 4h, 1d)
# El vídeo recomienda 15m para scalping
TIMEFRAME=15m

# Apalancamiento (1-125 según el par)
# ⚠️ CUIDADO: más leverage = más riesgo
LEVERAGE=5

# Porcentaje del balance a arriesgar por operación (0.01 = 1%)
# Con 5x leverage y 5% riesgo, expones el 25% del capital
RISK_PCT=0.05

# ── PARÁMETROS DE LA ESTRATEGIA ───────────────────────────────
# Longitud ZLEMA (defecto del indicador: 70)
ZLEMA_LENGTH=70

# Multiplicador de bandas (defecto: 1.2)
BAND_MULT=1.2

# Período oscilador de reversión
# Pine Script original: 20 | El vídeo de Whale Analytics recomienda: 50
# Prueba ambos en demo antes de decidir cuál usar
OSC_PERIOD=20

# ── REGLAS DE ENTRADA/SALIDA ──────────────────────────────────
# Entrar solo si la probabilidad de reversión es MENOR a este valor
# Si es 0.30, solo entra cuando el mercado lleva poco tiempo en la misma dirección
ENTRY_MAX_PROB=0.30

# Cerrar la posición cuando la probabilidad de reversión supere este valor
# 0.84 = nivel del 84% del indicador (recomendado en el vídeo)
EXIT_PROB=0.84

# ── OPERACIÓN ─────────────────────────────────────────────────
# Segundos entre cada comprobación del mercado
CHECK_INTERVAL=60

# Balance mínimo en USDT para abrir nuevas operaciones
MIN_BALANCE=10

# DEMO_MODE=true  → Usa la cuenta demo de BingX (sin dinero real)
# DEMO_MODE=false → Opera con dinero real ⚠️
DEMO_MODE=true
