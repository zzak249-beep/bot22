# ─────────────────────────────────────────────────────────
# AEGIS GEX Bot — Variables de entorno
# Copia este archivo como referencia.
# En Railway: Settings → Variables → añade cada clave.
# NUNCA subas este archivo con valores reales a GitHub.
# ─────────────────────────────────────────────────────────

# BingX API (Futuros Perpetuos)
BINGX_API_KEY=TU_API_KEY_DE_BINGX
BINGX_SECRET_KEY=TU_SECRET_KEY_DE_BINGX

# Telegram Bot
TELEGRAM_TOKEN=TU_TOKEN_DEL_BOT_TELEGRAM
TELEGRAM_CHAT_ID=TU_CHAT_ID_O_ID_DEL_CANAL

# Seguridad del webhook (pon una cadena aleatoria larga)
WEBHOOK_SECRET=una_clave_secreta_muy_larga_aqui

# Configuración de trading
ORDER_SIZE=0.01        # Tamaño de la orden (en contratos o USDT según el par)
LEVERAGE=5             # Apalancamiento (ej: 5 = 5x)
MODE=paper             # "paper" para simular, "live" para operar real

# Railway lo asigna automáticamente, no lo toques
# PORT=5000
