# ═══════════════════════════════════════════════════════════════
# Bot de Scalping Multi-Moneda - Configuración
# ═══════════════════════════════════════════════════════════════

# ─────────────────── CREDENCIALES BINGX ───────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui

# ─────────────────── TELEGRAM (OPCIONAL) ──────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────── SÍMBOLOS A TRADEAR ───────────────────────
# Lista de pares separados por coma
# Ejemplos populares:
# - Majors: BTC-USDT,ETH-USDT,BNB-USDT
# - DeFi: SOL-USDT,AVAX-USDT,MATIC-USDT
# - Altcoins: ADA-USDT,DOT-USDT,LINK-USDT,UNI-USDT
# - Memecoins: DOGE-USDT,SHIB-USDT,PEPE-USDT
# IMPORTANTE: Cuantos más símbolos, más oportunidades pero más capital necesario

SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,AVAX-USDT,MATIC-USDT,ADA-USDT,DOT-USDT

# ─────────────────── PARÁMETROS DE TRADING ────────────────────
# Timeframe de las velas (1m, 3m, 5m, 15m, 30m, 1h, 4h, 1d)
TIMEFRAME=15m

# Apalancamiento (1-125x) - ⚠️ Mayor apalancamiento = Mayor riesgo
LEVERAGE=5

# Porcentaje de balance arriesgado por operación (0.01-1.0)
# 0.05 = 5% del balance por trade
RISK_PCT=0.05

# Balance mínimo en USDT para operar
MIN_BALANCE=10

# Máximo de posiciones simultáneas (1-20)
# Más posiciones = mayor diversificación pero necesitas más capital
MAX_POSITIONS=3

# ─────────────────── ESTRATEGIA ZERO LAG ──────────────────────
# Longitud del Zero Lag EMA (20-200)
# Valores más bajos = más señales, más agresivo
# Valores más altos = menos señales, más conservador
ZLEMA_LENGTH=70

# Multiplicador de bandas (0.5-3.0)
# Valores más bajos = bandas más estrechas, más señales
BAND_MULT=1.2

# Período del oscilador (10-50)
OSC_PERIOD=20

# Probabilidad MÁXIMA para ENTRAR (0.0-1.0)
# Valor más bajo = más selectivo (menos trades)
# 0.65 = entrar solo si probabilidad de reversión < 65%
ENTRY_MAX_PROB=0.65

# Probabilidad MÍNIMA para SALIR (0.0-1.0)
# Valor más alto = salir más rápido
# 0.84 = salir si probabilidad de reversión >= 84%
EXIT_PROB=0.84

# ─────────────────── SISTEMA ───────────────────────────────────
# Intervalo entre checks en segundos
CHECK_INTERVAL=60

# Modo demo (true/false)
# true = No usa dinero real (testnet)
# false = Dinero real ⚠️
DEMO_MODE=false

# Modo de posición (auto, hedge, oneway)
# auto = detecta automáticamente
POSITION_MODE=auto

# Enviar reporte cada N ciclos (0 = desactivado)
REPORT_EVERY=60

# ═══════════════════════════════════════════════════════════════
# NOTAS IMPORTANTES:
# 
# 1. SÍMBOLOS:
#    - Más símbolos = más oportunidades pero necesitas más capital
#    - Recomendado: 3-8 símbolos con MAX_POSITIONS=2-4
#    - Asegúrate de tener suficiente balance para todas las posiciones
#
# 2. CAPITAL NECESARIO:
#    - Balance mínimo = MIN_BALANCE * MAX_POSITIONS
#    - Ejemplo: MIN_BALANCE=10, MAX_POSITIONS=3 → necesitas 30 USDT
#
# 3. RIESGO:
#    - RISK_PCT * LEVERAGE = exposición real
#    - Ejemplo: 5% * 5x = 25% de exposición por trade
#    - Con 3 posiciones simultáneas = 75% de exposición total
#
# 4. RECOMENDACIONES:
#    - Principiantes: LEVERAGE=3-5, MAX_POSITIONS=1-2, RISK_PCT=0.03
#    - Intermedio: LEVERAGE=5-10, MAX_POSITIONS=2-4, RISK_PCT=0.05
#    - Avanzado: LEVERAGE=10-20, MAX_POSITIONS=3-6, RISK_PCT=0.05-0.10
#
# 5. TELEGRAM:
#    - Opcional pero muy recomendado para monitoreo
#    - Recibirás notificaciones de entradas, salidas y errores
#
# ═══════════════════════════════════════════════════════════════
