# ═══════════════════════════════════════════════════════════════
# BingX Trading Bot — Variables de Entorno
# Copia como .env y completa tus valores reales
# NUNCA subas el .env a GitHub (está en .gitignore)
# ═══════════════════════════════════════════════════════════════

# ─── BINGX API ──────────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_de_bingx
BINGX_API_SECRET=tu_api_secret_de_bingx

# false = opera con DINERO REAL
# true  = modo simulación (no ejecuta órdenes reales)
TESTNET=true

# ─── TELEGRAM ───────────────────────────────────────────────────
TELEGRAM_TOKEN=tu_token_de_botfather
TELEGRAM_CHAT_ID=tu_chat_id_numerico

# ─── PARES (formato BingX Futuros Perpetuos) ────────────────────
TRADING_PAIRS=BTC-USDT,ETH-USDT,SOL-USDT

# ─── ENTRADA FIJA ───────────────────────────────────────────────
USDT_PER_TRADE=8     # USDT de margen por trade
LEVERAGE=7           # Apalancamiento
# Posición efectiva = 8 × 7 = 56 USDT

# ─── GESTIÓN DE RIESGO ──────────────────────────────────────────
MAX_POSITIONS=3      # Máx posiciones abiertas al mismo tiempo
MAX_DAILY_LOSS=5.0   # % pérdida diaria para pausar el bot

# ─── TIMEFRAMES ─────────────────────────────────────────────────
MEAN_REV_TIMEFRAME=15m   # VWAP + BB+RSI
SCALPING_TIMEFRAME=5m    # EMA Ribbon
ANALYSIS_INTERVAL=60     # Segundos entre escaneos de pares

# ─── ESTRATEGIAS ────────────────────────────────────────────────
VWAP_MIN_BAND=2      # Banda SD mínima para señal (2 o 3)
RSI_OVERSOLD=30      # Nivel sobreventa
RSI_OVERBOUGHT=70    # Nivel sobrecompra
