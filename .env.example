# ─── BingX API ─────────────────────────────────────────────────────────────
BINGX_API_KEY=your_bingx_api_key_here
BINGX_API_SECRET=your_bingx_api_secret_here

# ─── Telegram ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat_id via @userinfobot
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Trading config ────────────────────────────────────────────────────────
SYMBOL=BTC-USDT          # BingX symbol format (BTC-USDT, ETH-USDT, etc.)
INTERVAL=3m              # Candle timeframe: 1m 3m 5m 15m 30m 1h
LEVERAGE=5               # 1–125 (start low!)
DEMO_MODE=true           # true = paper trading, false = real money

# ─── EMA parameters (match Pine Script) ───────────────────────────────────
EMA1_LEN=2
EMA2_LEN=4
EMA3_LEN=20

# ─── Risk management ───────────────────────────────────────────────────────
RISK_PCT=1.0             # % of balance to risk per trade  (e.g. 1.0 = 1%)
SL_PCT=1.5               # Stop-loss distance from entry   (e.g. 1.5 = 1.5%)
TP_RATIO=2.0             # TP = SL distance × this ratio   (e.g. 2.0 = 3% TP)
MAX_DD_PCT=10.0          # Halt trading if drawdown > this % (e.g. 10.0 = 10%)

# ─── Misc ──────────────────────────────────────────────────────────────────
HEARTBEAT_EVERY=20       # Send Telegram heartbeat every N candles
