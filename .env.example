# ══════════════════════════════════════════════════════
#   BINGX FUTURES ARBITRAGE BOT v3.0 — Variables
#   Renombra a .env para local | Railway: pestaña Variables
# ══════════════════════════════════════════════════════

# ─── BINGX API ────────────────────────────────────────
# https://bingx.com/es-es/account/api
# Permisos: Futuros Perpetuos (NO retiros)
BINGX_API_KEY=pon_tu_api_key_aqui
BINGX_API_SECRET=pon_tu_api_secret_aqui

# ─── MODO ─────────────────────────────────────────────
DRY_RUN=true          # true=simulación | false=DINERO REAL ⚠️

# ─── CAPITAL Y COMPOUNDING ────────────────────────────
INITIAL_CAPITAL=20    # USDT con los que empiezas
COMPOUND_RATE=0.8     # 80% de cada ganancia se reinvierte
MAX_TRADE_USDT=500    # techo máximo por trade (protección)
MIN_TRADE_USDT=10     # suelo mínimo por trade

# ─── PARÁMETROS ───────────────────────────────────────
MIN_PROFIT_PCT=0.25   # % mínimo de ganancia neta
LOOP_INTERVAL=3       # segundos entre ciclos
FEE_RATE=0.001        # 0.1% por orden (0.00075 con BNB)
LEVERAGE=1            # 1x recomendado para arbitraje

# ─── RIESGO ───────────────────────────────────────────
MAX_DAILY_LOSS_USDT=50  # pausa si pierde este importe en el día

# ─── APRENDIZAJE ──────────────────────────────────────
BLACKLIST_THRESHOLD=0.4  # >40% fallo → blacklist temporal
BLACKLIST_MINUTES=30     # minutos bloqueado
MIN_TRADES_TO_SCORE=3    # mínimo de trades para puntuar una ruta

# ─── TELEGRAM ─────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
