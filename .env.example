# ══════════════════════════════════════════════════════════════════
#  QF×JP v3.5 PREDATOR — Multi-Symbol Scanner
#  Copia a .env y rellena tus valores.
#  En Railway → Variables tab, añade cada clave directamente.
# ══════════════════════════════════════════════════════════════════

# ── BingX API (Perpetuals — necesita permisos Read + Trade) ──────
BINGX_API_KEY=TU_API_KEY_AQUI
BINGX_SECRET_KEY=TU_SECRET_KEY_AQUI

# ── Telegram ─────────────────────────────────────────────────────
# 1. Habla con @BotFather → /newbot → copia el token
# 2. Añade el bot al canal y obtén el chat_id con @userinfobot
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890

# ── Scanner ───────────────────────────────────────────────────────
TIMEFRAME=3m              # temporalidad de velas: 1m 3m 5m 15m 1h
SCAN_INTERVAL=60          # segundos entre escaneos completos
MAX_SYMBOLS=80            # máximo de pares a escanear (top por volumen)
CONCURRENT_SCANS=10       # peticiones paralelas (no subir de 15)
MIN_VOLUME_USDT=500000    # volumen 24h mínimo para incluir el par

# ── Capital y riesgo ─────────────────────────────────────────────
CAPITAL=1000.0            # USDT disponible
RISK_PCT=1.0              # % capital arriesgado por trade
LEVERAGE=10               # apalancamiento perpetuos
TP1_MULT=1.5              # TP1 = entrada ± ATR × TP1_MULT
TP2_MULT=3.0
SL_MULT=1.0               # SL  = entrada ∓ ATR × SL_MULT
MAX_OPEN_TRADES=5         # posiciones abiertas simultáneas máximo
MAX_DAILY_TRADES=20       # trades diarios máximo

# ── Filtros de señal ──────────────────────────────────────────────
# Tier mínimo para abrir trade: STD | FUEL | SUP
MIN_TIER=FUEL
# Exigir ruptura de trendline como condición principal
REQUIRE_TL_BREAK=true
# Operar señales PRE (anticipatorias, más arriesgadas)
TRADE_PRE_SIGNALS=false
# HTF timeframes mínimos alineados (0-3)
HTF_MIN=2

# ── Umbrales del score compuesto (0-100) ─────────────────────────
SC_THR_PRE=48
SC_THR_STD=55
SC_THR_FUEL=68
SC_THR_SUP=80
