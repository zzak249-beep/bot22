# ═══════════════════════════════════════════════════════════
#  AEGIS GEX v5.0 — Variables de entorno para Railway
#  Settings → Variables → Add Variable (una por línea)
# ═══════════════════════════════════════════════════════════

# ── Exchange ──────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_aqui

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=tu_chat_id
WEBHOOK_SECRET=cualquier_clave_secreta

# ── Modo (empieza en paper, pasa a live tras 48h de validación) ──
MODE=paper

# ── Riesgo — CRÍTICO para cuenta de $100 ─────────────────
ACCOUNT_BALANCE=100       # Tu balance real en USDT
RISK_PER_TRADE=0.01       # 1% = $1 máximo en riesgo por trade
MAX_OPEN_TRADES=3         # Nunca más de 3 posiciones simultáneas
MAX_DAILY_LOSS=0.03       # Para todo si pierdes 3% en un día
LEVERAGE=3                # Máximo 3x con cuenta pequeña

# ── Ejecución inteligente ─────────────────────────────────
LIMIT_WAIT_SECS=8         # Segundos esperando fill de limit order
PRICE_SLIP_PCT=0.0005     # Tolerancia de slippage al colocar limit

# ── Multi-Timeframe ───────────────────────────────────────
MTF_CONFLUENCE_MIN=0.55   # 55% de confluencia mínima entre TFs

# ── Señales ───────────────────────────────────────────────
ZSCORE_WINDOW=20
ZSCORE_THRESHOLD=2.5      # La IA lo ajustará automáticamente
WHALE_VOL_MULT=2.5
CVD_THRESHOLD=0.6
ABSORPTION_VOL=3.0
ABSORPTION_MOVE=0.002

# ── Trailing Stop ─────────────────────────────────────────
TRAILING_PCT=0.8          # Cierra si retrocede 0.8% desde máximo
TRAILING_CHECK=10         # Chequea cada 10 segundos

# ── Scanner ───────────────────────────────────────────────
SCANNER_ENABLED=true
SCAN_INTERVAL=60          # Escanea cada 60 segundos
SIGNAL_COOLDOWN=300       # No repite señal del mismo par en 5 min

# ── Símbolos (opcional, usa los 6 por defecto si no se especifica) ──
# SCAN_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT
