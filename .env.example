# ══════════════════════════════════════════
#  QF×JP Bot v4.0 — Variables de Entorno
# ══════════════════════════════════════════

BINGX_API_KEY=tu_api_key
BINGX_SECRET=tu_secret

TG_TOKEN=123456:ABCdef...
TG_CHAT_ID=-100123456789

# SIGNAL = solo alertas | LIVE = dinero real
MODE=SIGNAL

# AUTO = escanea todos los pares BingX por volumen
# MANUAL = usa la lista SYMBOLS
SYMBOLS_MODE=AUTO
MIN_VOLUME_USDT=50000000
MAX_SYMBOLS=25

# Solo si SYMBOLS_MODE=MANUAL
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT

# Riesgo
LEVERAGE=10
RISK_PCT=1.0
MAX_DD_PCT=5.0
MAX_POSITIONS=5
TP_RR=2.0

# Umbrales optimizados (NO tocar sin backtest)
SCORE_THR_LONG=0.63
SCORE_THR_SHORT=0.63
DECAY_THR=0.65

# Convicción mínima
MIN_CONV_STD=6
MIN_CONV_FUEL=7
MIN_CONV_SUP=8

# Profit Factor mínimo para operar un símbolo
MIN_PF=1.5
PF_WINDOW=20

# Sesiones: NY, LDN, ASIA
SESSIONS=NY,LDN

LOOP_INTERVAL=30
SCANNER_INTERVAL=3600
