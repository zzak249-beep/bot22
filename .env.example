# ═══════════════════════════════════════════════════════════════════
# INSTITUTIONAL BOT v3.1 — RAILWAY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
# 
# INSTRUCCIONES:
# 1. Ve a tu proyecto en Railway
# 2. Click en "Variables" tab
# 3. Añade cada variable de abajo (sin las líneas que empiezan con #)
# 4. NO subas este archivo con tus claves reales
#
# ═══════════════════════════════════════════════════════════════════

# ── API CREDENTIALS (REQUERIDO) ────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_API_SECRET=tu_api_secret_aqui

# ── TELEGRAM (OPCIONAL pero recomendado) ───────────────────────────
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ── TRADING MODE (⚠️ MUY IMPORTANTE) ───────────────────────────────
# false = PAPER MODE (simulación, NO gasta dinero real)
# true = REAL MONEY (trading real, usa con EXTREMA precaución)
AUTO_TRADING_ENABLED=false

# ── CAPITAL MANAGEMENT ─────────────────────────────────────────────
# Tamaño de posición en USD (conservador = 10, agresivo = 20)
POSITION_SIZE_USD=10

# Leverage (conservador = 2, agresivo = 3, NUNCA >5)
LEVERAGE=2

# Máximo de posiciones simultáneas (conservador = 2, agresivo = 4)
MAX_POSITIONS=2

# Equity total de la cuenta en USD
ACCOUNT_EQUITY=100

# Riesgo por trade en % del equity (conservador = 1.0, agresivo = 2.0)
RISK_PCT_PER_TRADE=1.0

# ── STOP LOSS & TAKE PROFIT ────────────────────────────────────────
# Multiplicador ATR para stop loss (conservador = 1.5, ajustado = 1.2)
SL_ATR_MULTIPLIER=1.5

# SL mínimo en % (evita stops demasiado ajustados)
SL_MIN_PCT=0.8

# SL máximo en % (evita stops demasiado amplios)
SL_MAX_PCT=2.0

# % de posición a cerrar en TP1 (recomendado: 35-40)
TP1_PERCENTAGE=40

# % de posición a cerrar en TP2 (recomendado: 35-40)
TP2_PERCENTAGE=40

# Risk:Reward ratio para TP1 (conservador = 1.5, agresivo = 1.2)
TP1_RISK_REWARD=1.5

# Risk:Reward ratio para TP2 (conservador = 2.5, agresivo = 2.0)
TP2_RISK_REWARD=2.5

# Multiplicador ATR para trailing stop del runner
RUNNER_TRAIL_ATR=2.0

# Edge mínimo requerido (conservador = 4.0, agresivo = 3.0)
MIN_EDGE_RATIO=4.0

# ── FILTROS DE MERCADO ─────────────────────────────────────────────
# Volumen 24h mínimo en USD (filtro de liquidez)
MIN_VOLUME_24H=2000000

# Máximo de símbolos a escanear (menos = más rápido)
MAX_SYMBOLS=30

# Score mínimo para abrir posición (conservador = 75, agresivo = 70)
MIN_ENTRY_SCORE=75

# ── FILTROS v3.0 ───────────────────────────────────────────────────
# Multiplicador de volumen para breakout (conservador = 1.8, agresivo = 1.5)
VOLUME_BREAKOUT_MULT=1.8

# ATR mínimo en % (filtro de rango lateral)
REGIME_ATR_MIN_PCT=0.5

# ATR máximo en % (filtro de volatilidad extrema)
REGIME_ATR_MAX_PCT=3.5

# Barras para detectar VCP pattern
VCP_LOOKBACK=20

# Máximo de altcoins correlacionadas simultáneas
MAX_CORR_LONGS=1

# Requiere confirmación EMA9 (true = más estricto)
EMA9_REQUIRED=true

# ── FUNDING RATE FILTER ────────────────────────────────────────────
# Activar filtro de funding rate (true recomendado)
FUNDING_FILTER=true

# Funding rate máximo OK para long (en %)
FUNDING_LONG_OK=0.03

# Funding rate donde skipear long (en %)
FUNDING_LONG_SKIP=0.05

# ── OPEN INTEREST FILTER ───────────────────────────────────────────
# Activar filtro de OI (true recomendado)
OI_FILTER=true

# OI mínimo para confirmar breakout
OI_BREAKOUT_MIN=1.5

# OI bajo indica divergencia débil
OI_WEAK_THRESHOLD=0.5

# ── SESSION FILTER ─────────────────────────────────────────────────
# Activar filtro de sesión (true = solo opera en mejores horas)
SESSION_FILTER=true

# ── CVD (Cumulative Volume Delta) ──────────────────────────────────
# Barras para calcular CVD
CVD_LOOKBACK_BARS=20

# Threshold de CVD (mayor = más estricto)
CVD_THRESHOLD=1.5

# ── CIRCUIT BREAKER (⚠️ PROTECCIÓN CRÍTICA) ────────────────────────
# Pérdida diaria máxima en % antes de pausar (conservador = 3.0)
CIRCUIT_BREAKER_PCT=3.0

# Máxima racha perdedora antes de pausar (conservador = 3)
MAX_LOSING_STREAK=3

# Máximo de trades por día (evita overtrading)
MAX_DAILY_TRADES=8

# ── TIMING ─────────────────────────────────────────────────────────
# Intervalo de escaneo en segundos (60-120 recomendado)
SCAN_INTERVAL_SEC=90

# Intervalo de monitoreo de posiciones en segundos
MONITOR_INTERVAL_SEC=20

# ═══════════════════════════════════════════════════════════════════
# NOTAS IMPORTANTES:
# ═══════════════════════════════════════════════════════════════════
#
# 1. EMPIEZA SIEMPRE CON AUTO_TRADING_ENABLED=false
# 2. Usa estos valores conservadores por defecto
# 3. NO cambies parámetros después de 2-3 trades malos
# 4. Dale al menos 50 trades antes de modificar configuración
# 5. Si cambias algo, cambia UNA variable a la vez
# 6. Monitorea logs en Railway después de cada cambio
#
# ═══════════════════════════════════════════════════════════════════
