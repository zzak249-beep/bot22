# ══════════════════════════════════════════════════════════════
#  EDGE BOT v5 — Variables de entorno para Railway
# ══════════════════════════════════════════════════════════════

# ── API BingX (https://bingx.com → Account → API Management) ──
BINGX_API_KEY=tu_api_key
BINGX_API_SECRET=tu_api_secret

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_TOKEN=token_de_botfather
TELEGRAM_CHAT_ID=tu_chat_id

# ── Modo ───────────────────────────────────────────────────────
DRY_RUN=true          # true=simulación | false=real (¡cuidado!)

# ── Símbolos ───────────────────────────────────────────────────
SYMBOLS=              # vacío = escanea automáticamente
LIQUIDITY_MODE=high_only  # high_only | all

# ── Estrategia ────────────────────────────────────────────────
SCORE_MIN=60          # mínimo 60/100 para operar (no bajar de 55)
ADX_MIN=25            # fuerza mínima de tendencia

# ── ATR multipliers ───────────────────────────────────────────
ATR_SL_MULT=1.5       # SL = ATR × 1.5
ATR_TP1_MULT=2.25     # TP1 = ATR × 2.25 (RR 1.5) — cierra 50%
ATR_TP2_MULT=3.5      # TP2 = ATR × 3.5  (RR 2.3) — cierra 25%
ATR_TP3_MULT=6.0      # TP3 = ATR × 6.0  (RR 4.0) — cierra 25%

# ── Gestión de riesgo ─────────────────────────────────────────
LEVERAGE=5            # apalancamiento (3-5 recomendado)
MAX_OPEN_TRADES=3     # máximo posiciones simultáneas
MAX_DD_DAY_PCT=5.0    # pausa si pérdida diaria > 5%
MAX_DD_WEEK_PCT=12.0  # pausa si pérdida semanal > 12%
MAX_SIGNALS_DAY=15    # máximo trades por día

# ── Liquidez ──────────────────────────────────────────────────
MIN_VOL_USDT=1000000  # volumen mínimo por vela (1M USDT)

# ── Trailing stop ─────────────────────────────────────────────
TRAIL_PCT=0.35        # distancia trailing en %

# ── Timing ────────────────────────────────────────────────────
SCAN_INTERVAL=180     # segundos entre scans (3 min = 1 vela 3m)
HEARTBEAT_EVERY=20    # heartbeat cada 20 scans = 1 hora
COOLDOWN_BARS=4       # velas entre señales del mismo par
