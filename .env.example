# ══════════════════════════════════════════════════
#   BINGX ARBITRAGE BOT v2.0 — Variables de entorno
#   Renombra este archivo a .env para usar en local
#   En Railway: pégalas en la pestaña "Variables"
# ══════════════════════════════════════════════════

# ─── BINGX API ────────────────────────────────────
# Crea tus keys en: https://bingx.com/es-es/account/api
# Permisos necesarios: Spot Trading (NO retiros)
BINGX_API_KEY=pon_tu_api_key_aqui
BINGX_API_SECRET=pon_tu_api_secret_aqui

# ─── MODO ─────────────────────────────────────────
# true  = simulación, no ejecuta órdenes reales
# false = DINERO REAL ⚠️  — solo cuando estés seguro
DRY_RUN=true

# ─── PARÁMETROS DEL BOT ───────────────────────────
MIN_PROFIT_PCT=0.25       # % mínimo de ganancia neta (después de fees)
TRADE_AMOUNT=20           # USDT que se mueven en cada triángulo
LOOP_INTERVAL=3           # segundos entre ciclos de escaneo
FEE_RATE=0.001            # fee por orden (0.1% Binance spot, 0.00075 con BNB)

# ─── GESTIÓN DE RIESGO ────────────────────────────
MAX_DAILY_LOSS_USDT=50    # bot se pausa si pierde esta cantidad en el día

# ─── TELEGRAM (opcional pero recomendado) ─────────
# Cómo obtener el token:
#   1. Habla con @BotFather en Telegram → /newbot → copia el token
# Cómo obtener el chat_id:
#   2. Envía cualquier mensaje a tu nuevo bot
#   3. Abre: https://api.telegram.org/bot<TOKEN>/getUpdates
#   4. Copia el valor de "id" dentro del objeto "chat"
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
