# ── BingX ──────────────────────────────────────────────────────────────────
BINGX_API_KEY=tu_api_key
BINGX_API_SECRET=tu_secret_key

# ── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=tu_chat_id

# ── Trading ────────────────────────────────────────────────────────────────
DEMO_MODE=false
SYMBOL=                  # vacío = scanner automático 30 pares
INTERVAL=3m
HTF_INTERVAL=15m         # timeframe mayor para sesgo de tendencia
LEVERAGE=5

# ── Estrategia ─────────────────────────────────────────────────────────────
EMA1_LEN=2
EMA2_LEN=4
EMA3_LEN=20
SCORE_MIN=40             # score mínimo señal para operar (0=todas, 60=solo las mejores)

# ── Riesgo ─────────────────────────────────────────────────────────────────
RISK_PCT=1.0             # % balance por trade
ATR_SL_MULT=1.5          # SL = ATR × este multiplicador (más adaptativo que % fijo)
MAX_DD_PCT=10.0          # pausa automática si drawdown supera este %

# ── Scanner ────────────────────────────────────────────────────────────────
SCANNER_TOP_N=1          # operar solo el mejor par
MIN_VOLUME=2000000       # volumen mínimo 24h en USD (2M)

# ── Notificaciones ─────────────────────────────────────────────────────────
HEARTBEAT_EVERY=20       # heartbeat cada N velas
