# ─── BINGX ───────────────────────────────────────────────────
# Crea tus keys en: https://bingx.com/es-es/account/api
# Permisos necesarios: Leer + Operar Futuros (NO retiros)
BINGX_API_KEY=tu_api_key_aqui
BINGX_API_SECRET=tu_api_secret_aqui

# ─── MODO ────────────────────────────────────────────────────
DRY_RUN=true          # true = simulación | false = DINERO REAL ⚠️

# ─── MERCADO ─────────────────────────────────────────────────
SYMBOL=BTC/USDT:USDT  # perpetual futures BingX
TIMEFRAME=2h
LEVERAGE=5            # apalancamiento (recomendado: 3–5x)

# ─── RIESGO POR TRADE ────────────────────────────────────────
RISK_PCT=1.0           # % del balance a arriesgar por trade
MAX_DAILY_LOSS_PCT=3.0 # bot se pausa si pierde este % en el día
MAX_TRADES_DAY=5       # máximo trades por día

# ─── TAKE PROFIT / STOP LOSS ────────────────────────────────
TP1_RR=1.0             # TP1 a 1:1 (cierra 50%)
TP2_RR=2.0             # TP2 a 1:2 (cierra restante)
TP1_QTY_PCT=50         # % de la posición que cierra en TP1
MIN_ATR_MULT=0.5       # SL mínimo = 0.5 × ATR (evita SL muy ajustados)

# ─── FILTROS (mejoras vs Pine Script original) ───────────────
RSI_PERIOD=14
RSI_BULL_MIN=45        # LONG solo si RSI > 45
RSI_BEAR_MAX=55        # SHORT solo si RSI < 55
VOL_MA_PERIOD=20       # volumen debe superar su media de 20 velas
COOLDOWN_BARS=3        # velas de espera después de un SL

# ─── LOOP ────────────────────────────────────────────────────
CHECK_INTERVAL=60      # segundos entre chequeos (recomendado: 60)

# ─── TELEGRAM ────────────────────────────────────────────────
# 1. Habla con @BotFather → /newbot → copia el token
# 2. Envía un mensaje a tu bot
# 3. Abre: https://api.telegram.org/bot<TOKEN>/getUpdates
# 4. Copia el "id" dentro de "chat"
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
