# ═══════════════════════════════════════════════════════════════════
# AEGIS GEX APEX QUANT v6.1 — Variables de entorno
# Copia este archivo como .env para desarrollo local
# En Railway: configura estas variables en "Variables" del servicio
# ═══════════════════════════════════════════════════════════════════

# ── CREDENCIALES BINGX ─────────────────────────────────────────────
# ⚠️  NOMBRES EXACTOS — el código usa BINGX_API_KEY y BINGX_SECRET_KEY
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_api_secret_aqui

# ── MODO DE OPERACIÓN ──────────────────────────────────────────────
# "paper" = simulado (sin dinero real) | "live" = dinero real
MODE=paper

# ── TELEGRAM (opcional pero recomendado) ──────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── CAPITAL ───────────────────────────────────────────────────────
ORDER_SIZE=10
LEVERAGE=3
MAX_POSITIONS=2

# ── SCANNER ───────────────────────────────────────────────────────
SCANNER_ENABLED=true
SCAN_INTERVAL=60
SCAN_TIMEFRAME=15m
CONFIRM_TIMEFRAME=1h

# ── FILTROS ───────────────────────────────────────────────────────
SESSION_FILTER=true
SESSION_HOUR_START=13
SESSION_HOUR_END=22
FUNDING_FILTER=true
FUNDING_MAX=0.05

# ── RIESGO ────────────────────────────────────────────────────────
TRAILING_ENABLED=true
TRAILING_PCT=0.8
SL_PCT=2.0
CB_MAX_LOSS_PCT=4.0
CB_MAX_STREAK=3

# ── INDICADORES ───────────────────────────────────────────────────
ZSCORE_THRESHOLD=2.5
ZSCORE_WINDOW=20
ABSORPTION_VOL_MULT=3.0
WHALE_VOL_MULTIPLIER=2.5
CVD_THRESHOLD=0.6

# ── HMM ───────────────────────────────────────────────────────────
HMM_MIN_BARS=80
HMM_N_ITER=100

# ── INTELIGENCIA ──────────────────────────────────────────────────
FNG_FILTER=true
SPX_FILTER=true
OI_FILTER=true
LIQ_FILTER=true
BTCD_FILTER=true
OI_CHANGE_MIN=2.0
BTCD_THRESHOLD=0.5
LIQ_MIN_USD=500000

# ── FUNDING HARVEST ───────────────────────────────────────────────
HARVEST_ENABLED=true
HARVEST_MIN_RATE=0.05
HARVEST_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT
HARVEST_MONITOR=300

# ── WEBHOOK ───────────────────────────────────────────────────────
WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────
# ⚠️  CHECKLIST ANTES DE PONER MODE=live:
#   [ ] Testear 1 semana en MODE=paper
#   [ ] Verificar que BINGX_SECRET_KEY funciona (endpoint /status)
#   [ ] Confirmar TELEGRAM funciona (recibes mensajes)
#   [ ] Circuit breaker configurado (CB_MAX_LOSS_PCT)
#   [ ] Empezar con ORDER_SIZE pequeño (5-10 USD)
# ─────────────────────────────────────────────────────────────────
