# ══════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL BOT DE TRADING AVANZADO
# ══════════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────────────
# API CREDENTIALS (REQUERIDAS)
# ────────────────────────────────────────────────────────────────────────────
# Obtén tus claves API en: https://bingx.com/en-us/account/api/
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET=tu_secret_key_aqui

# Telegram Bot (para notificaciones)
# Crea un bot con @BotFather en Telegram
TG_TOKEN=tu_telegram_bot_token
TG_CHAT_ID=tu_chat_id_de_telegram

# ────────────────────────────────────────────────────────────────────────────
# TRADING PARAMETERS
# ────────────────────────────────────────────────────────────────────────────

# Par de trading
SYMBOL=BTC-USDT

# Timeframe (1m, 3m, 5m, 15m, 30m, 1h, 4h, 1d)
TIMEFRAME=15m

# Porcentaje de riesgo por trade (1.0 = 1% del balance)
RISK_PCT=1.0

# Apalancamiento (leverage)
LEVERAGE=10

# Multiplicador de ATR para Stop Loss y Take Profits
ATR_MULTIPLIER=1.5

# Intervalo de polling en segundos
POLL_SECONDS=60

# ────────────────────────────────────────────────────────────────────────────
# STRATEGY CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────

# Estrategia a usar: "sniper", "vwap", o "hybrid"
# - sniper: Solo usa cruces de EMA 9/21
# - vwap: Solo usa VWAP Volatility Bands
# - hybrid: Combina ambas (requiere confluencia)
STRATEGY=hybrid

# Diferencia mínima de score para señales STRONG (0-100)
MIN_SCORE_DIFF=40.0

# ────────────────────────────────────────────────────────────────────────────
# COMMISSION SETTINGS
# ────────────────────────────────────────────────────────────────────────────

# BingX fees (por defecto)
# Maker: 0.02% | Taker: 0.05%
MAKER_FEE=0.0002
TAKER_FEE=0.0005

# ────────────────────────────────────────────────────────────────────────────
# BOT BEHAVIOR
# ────────────────────────────────────────────────────────────────────────────

# Modo solo señales (no ejecuta trades reales)
# true = Solo envía señales por Telegram
# false = Ejecuta trades reales en BingX
SIGNALS_ONLY=false

# Intervalo de heartbeat en horas
HEARTBEAT_HOURS=4

# ══════════════════════════════════════════════════════════════════════════════
# NOTAS IMPORTANTES
# ══════════════════════════════════════════════════════════════════════════════
#
# 1. NUNCA compartas tus API keys con nadie
# 2. Empieza con SIGNALS_ONLY=true para probar
# 3. Usa apalancamiento bajo (5-10x) al principio
# 4. El bot ajusta TPs automáticamente para cubrir comisiones
# 5. Revisa métricas regularmente en /tmp/performance_metrics.json
#
# ══════════════════════════════════════════════════════════════════════════════
