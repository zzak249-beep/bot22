# Bot Supertrend + Unicorn Model (standalone) — variables de entorno
# Copiar a .env para correr local: cp .env.example .env
# En Railway: pegar cada una en el panel de Variables del servicio.

# ── Credenciales BingX ────────────────────────────────────────────────
BINGX_API_KEY=
BINGX_API_SECRET=
BINGX_BASE_URL=https://open-api.bingx.com
BINGX_DEMO_MODE=False
DRY_RUN=True

# ── Scanner ────────────────────────────────────────────────────────────
SCAN_CONCURRENCY=5
SCAN_INTERVAL_SEC=420
MIN_24H_VOLUME_USDT=3000000
SCAN_ALL_SYMBOLS=True
REQUIRE_USDT_QUOTE=True
ENABLE_FAST_SCAN=True
FAST_SCAN_TOP_N=60
FAST_SCAN_INTERVAL_SEC=60
MAX_ACTIVE_POSITIONS=6

# ── Timeframes ─────────────────────────────────────────────────────────
ENTRY_TF=3m
BIAS_TF=1h
HTF_A_TF=15m
HTF_B_TF=30m
HTF_C_TF=1h
OB_TF=15m

# ── Supertrend (BigBeluga custom) ─────────────────────────────────────
ST_LEN=50
ST_MULT=3.5

# ── Unicorn Model ──────────────────────────────────────────────────────
UNICORN_SWEEP_LB=30
UNICORN_REQUIRE_FVG=True
UNICORN_RR=1.5
UNICORN_SL_ATR_BUFFER=0.2
DIRECTION=BOTH
BREAKER_MIN_ATR=0.3
BREAKER_MAX_ATR=3.0

# ── Order Block Engine (BigBeluga) — motor de entrada en paralelo ────────
ENABLE_OB_ENGINE=True
OB_PIVOT_LEN=7
OB_MIN_BUY_PCT=50.0
OB_MIN_SELL_PCT=50.0
OB_DELETE_ON_BREAK=True
OB_RR=1.5
OB_SL_ATR_BUFFER=0.2

# ── CVD Filter (Cumulative Volume Delta, reusa candles_entry, sin llamada extra) ──
ENABLE_CVD_FILTER=False
CVD_LOOKBACK=20

# ── Order Book Imbalance (libro de órdenes en vivo, confirmación final) ──
ENABLE_OBI_FILTER=False
OBI_LEVELS=20
OBI_THRESHOLD=0.15

DEDUP_COOLDOWN_SEC=300

# ── Order Flow / Absorción (solo aplica a señales del Unicorn Model) ─────
ENABLE_ORDER_FLOW_FILTER=False
ORDER_FLOW_TRADES_LIMIT=1000
ORDER_FLOW_MIN_ABSORPTION_RATIO=0.55
ORDER_FLOW_MIN_VOLUME=0

# ── Funding Rate + Open Interest ─────────────────────────────────────────
ENABLE_FUNDING_OI_FILTER=False
FUNDING_OI_MODE=inform
FUNDING_EXTREME_THRESHOLD=0.0005
OI_MIN_CHANGE_PCT=1.0

# ── Regime Filter (Choppiness Index) ────────────────────────────────────
ENABLE_REGIME_FILTER=True
REGIME_CHOP_LENGTH=14
REGIME_CHOP_THRESHOLD=61.8

# ── Correlation Manager ───────────────────────────────────────────────────
ENABLE_CORRELATION_FILTER=True
CORR_THRESHOLD=0.75
CORR_LOOKBACK=30
MAX_CORRELATED_POSITIONS=2

# ── Persistencia (Railway Volume — montar en /data) ──────────────────────
DATA_DIR=/data

# ── Setup Memory (aprendizaje adaptativo) ────────────────────────────────
ENABLE_SETUP_MEMORY_FILTER=True
SETUP_MEMORY_MIN_SAMPLES=15
SETUP_MEMORY_MIN_WIN_RATE=0.35

# ── Gestión de riesgo ───────────────────────────────────────────────────
RISK_PCT_PER_TRADE=0.5
LEVERAGE=10
DAILY_MAX_LOSS_PCT=5.0
MAX_CONCURRENT_RISK_PCT=3.0

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
